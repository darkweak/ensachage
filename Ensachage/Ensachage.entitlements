<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  The App Sandbox is intentionally disabled: Ensachage spawns `/usr/bin/log`
	  to stream the system unlock log, which a sandboxed app may not do.
	  The camera entitlement is required because the Hardened Runtime is enabled;
	  actual access is still gated by TCC via NSCameraUsageDescription.
	-->
	<key>com.apple.security.device.camera</key>
	<true/>
	<!--
	  Required (Hardened Runtime) to send Apple events in-process to Mail and
	  Messages for the automatic owner alerts. Access is still gated by TCC
	  (Automation permission) and NSAppleEventsUsageDescription.
	-->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
</dict>
</plist>
