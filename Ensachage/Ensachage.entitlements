<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  The App Sandbox is intentionally disabled: Ensachage spawns `/usr/bin/log`
	  to stream the system unlock log, which a sandboxed app may not do.
	  Camera access is still gated by TCC via NSCameraUsageDescription.
	-->
</dict>
</plist>
